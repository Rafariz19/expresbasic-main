<%- include('../partials/_head.ejs') %>
<%- include('../partials/_message.ejs')%>

<div class="mb-4">
  <h4 class="fw-bold mb-0" style="font-size: 20px;"><%= title %></h4>
</div>

<div class="card" style="max-width: 480px;">
  <div class="card-body">
    <form action="/kategori/store" method="POST">
      <div class="mb-4">
        <label class="form-label">Nama Kategori</label>
        <input type="text" class="form-control" name="nama_kategori" placeholder="Masukkan nama kategori" required>
      </div>
      <div class="d-flex gap-2">
        <a href="/kategori" class="btn btn-outline-primary flex-fill">Kembali</a>
        <button type="submit" class="btn btn-success flex-fill">Simpan</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/_foot.ejs') %>
