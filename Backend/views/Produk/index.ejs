<%- include('../partials/_head.ejs')%>
<div class="container mt-5">
    <!-- Alert -->
<%- include('../partials/_message.ejs')%>
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Data Produk</h5>
            <a href="/produk/create" class="btn btn-sm btn-success">
                + Tambah Produk
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Nama Produk</th>
                        <th>Harga</th>
                        <th>Kategori</th>
                        <th>Gambar</th>
                        <th width="200">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (produk.length) { %>
                        <% for (var i = 0; i < produk.length; i++) { %>
                            <tr>
                                <td><%= produk[i].no %></td>
                                <td class="text-start"><%= produk[i].nama %></td>
                                <td><%= produk[i].harga %></td>
                                <td><%= produk[i].kategori %></td>
                                <td>
                                    <% if (produk[i].foto) { %>
                                        <img src="<%= produk[i].foto %>" alt="Gambar Produk" class="img-fluid" style="max-height:80px; max-width:80px; object-fit:cover;">
                                    <% } else { %>
                                        <span class="text-muted">Tidak ada</span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/produk/edit/<%= produk[i].no %>" 
                                       class="btn btn-sm btn-warning me-1">
                                        Edit
                                    </a>
                                    <a href="/produk/delete/<%= produk[i].no %>" 
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-muted py-4">
                                Data produk belum tersedia
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <% if (totalPages > 1) { %>
    <nav aria-label="Pagination" class="mt-3">
        <ul class="pagination justify-content-center">
            <% for (let page = 1; page <= totalPages; page++) { %>
            <li class="page-item <%= page === currentPage ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= page %>"><%= page %></a>
            </li>
            <% } %>
        </ul>
    </nav>
    <% } %>

    <div class="mt-3 text-center text-muted">
        Total Data: <%= totalData %>
    </div>

</div>

<!-- Bootstrap JS -->
<%- include('../partials/_foot.ejs')%>