<%- include('../partials/_head.ejs') %>

<div class="mb-4">
  <h4 class="fw-bold mb-0" style="font-size: 20px;">Hapus Produk</h4>
</div>

<div class="card" style="max-width: 520px;">
  <div class="card-body">
    <div class="text-center mb-4">
      <div style="font-size: 40px; color: #ef4444; margin-bottom: 8px;">&#9888;</div>
      <p class="fw-medium mb-1">Yakin ingin menghapus produk ini?</p>
      <p class="text-muted" style="font-size: 13px;">Tindakan ini tidak dapat dibatalkan.</p>
    </div>

    <div class="delete-info mb-4">
      <dl class="mb-0">
        <dt>Nama Produk</dt>
        <dd><%= nama_produk %></dd>
        <dt>Harga</dt>
        <dd>Rp <%= Number(harga_produk).toLocaleString('id-ID') %></dd>
        <dt>Kategori</dt>
        <dd><%= id_kategori %></dd>
      </dl>
    </div>

    <% if (gambar_produk) { %>
      <div class="text-center mb-4">
        <img src="<%= gambar_produk %>" alt="Gambar" class="img-fluid rounded" style="max-height: 180px;">
      </div>
    <% } %>

    <form action="/produk/destroy/<%= id_produk %>" method="POST">
      <div class="d-flex gap-2">
        <a href="/produk" class="btn btn-outline-primary flex-fill">Batal</a>
        <button type="submit" class="btn btn-danger flex-fill">Hapus</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/_foot.ejs') %>
