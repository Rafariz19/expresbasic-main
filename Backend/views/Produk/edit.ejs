<%- include('../partials/_head.ejs') %>
<%- include('../partials/_message.ejs')%>

<div class="mb-4">
  <h4 class="fw-bold mb-0" style="font-size: 20px;"><%= title %></h4>
</div>

<div class="card" style="max-width: 640px;">
  <div class="card-body">
    <form action="/produk/update/<%= id_produk %>" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="nama_produk" class="form-label">Nama Produk</label>
        <input type="text" class="form-control" id="nama_produk" name="nama_produk" value="<%= nama_produk %>" required>
      </div>
      <div class="mb-3">
        <label for="harga_produk" class="form-label">Harga</label>
        <input type="number" class="form-control" id="harga_produk" name="harga_produk" value="<%= harga_produk %>" required>
      </div>
      <div class="mb-3">
        <label for="id_kategori" class="form-label">Kategori</label>
        <select class="form-select" id="id_kategori" name="id_kategori" required>
          <option value="">-- Pilih Kategori --</option>
          <% kategori.forEach(function(kat) { %>
            <option value="<%= kat.id_kategori %>" <%= id_kategori == kat.id_kategori ? 'selected' : '' %>><%= kat.nama_kategori %></option>
          <% }); %>
        </select>
      </div>
      <div class="mb-3">
        <label for="gambar_produk" class="form-label">Gambar Produk</label>
        <input type="file" class="form-control" id="gambar_produk" name="gambar_produk" accept="image/*">
        <div class="form-text mt-1">Biarkan kosong untuk mempertahankan gambar saat ini.</div>
      </div>
      <div class="mb-4">
        <label class="form-label">Preview</label>
        <div class="border rounded p-3 text-center bg-light">
          <% if (gambar_produk) { %>
            <img id="preview-gambar" src="<%= gambar_produk %>" alt="Preview" class="img-fluid" style="max-height: 220px; display: block;">
            <p id="preview-placeholder" class="text-muted mb-0" style="font-size: 13px; display: none;">Belum memilih gambar</p>
          <% } else { %>
            <img id="preview-gambar" src="" alt="Preview" class="img-fluid" style="max-height: 220px; display: none;">
            <p id="preview-placeholder" class="text-muted mb-0" style="font-size: 13px;">Belum memilih gambar</p>
          <% } %>
        </div>
      </div>
      <div class="d-flex gap-2">
        <a href="/produk" class="btn btn-outline-primary flex-fill">Kembali</a>
        <button type="submit" class="btn btn-primary flex-fill">Update</button>
      </div>
    </form>
  </div>
</div>

<script>
  const editInput = document.getElementById('gambar_produk');
  if (editInput) {
    editInput.addEventListener('change', function() {
      const file = this.files[0];
      const preview = document.getElementById('preview-gambar');
      const placeholder = document.getElementById('preview-placeholder');
      if (!file) {
        if (preview && preview.src) {
          placeholder.style.display = 'none';
        } else {
          placeholder.style.display = 'block';
        }
        return;
      }
      const reader = new FileReader();
      reader.onload = function(e) {
        preview.src = e.target.result;
        preview.style.display = 'block';
        placeholder.style.display = 'none';
      };
      reader.readAsDataURL(file);
    });
  }
</script>
<%- include('../partials/_foot.ejs') %>
