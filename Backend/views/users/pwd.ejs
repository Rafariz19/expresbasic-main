<%- include('../partials/_head') %>
<%- include('../partials/_message') %>

<div class="mb-4">
  <h4 class="fw-bold mb-0" style="font-size: 20px;">Ganti Password</h4>
</div>

<div class="card" style="max-width: 480px;">
  <div class="card-body">
    <form action="/users/changepwd" method="POST">
      <div class="mb-4">
        <label class="form-label">New Password</label>
        <input type="password" name="password" class="form-control" placeholder="Masukkan password baru" required>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success flex-fill">Save Change</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/_foot') %>
