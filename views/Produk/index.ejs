<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
<div class="container mt-5">
    <!-- Alert -->
    <% if (messages.success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= messages.success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Data Produk</h5>
            <a href="/produk/create" class="btn btn-sm btn-success">
                + Tambah Produk
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Nama Produk</th>
                        <th>Harga</th>
                        <th>Kategori</th>
                        <th>Gambar</th>
                        <th width="200">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (data.length) { %>
                        <% for (var i = 0; i < data.length; i++) { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td class="text-start"><%= data[i].nama_produk %></td>
                                <td><%= data[i].harga_produk %></td>
                                <td><%= data[i].id_kategori %></td>
                                <td>
                                    <% if (data[i].gambar_produk) { %>
                                        <img src="<%= data[i].gambar_produk %>" alt="Gambar Produk" class="img-fluid" style="max-height:80px; max-width:80px; object-fit:cover;">
                                    <% } else { %>
                                        <span class="text-muted">Tidak ada</span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/produk/edit/<%= data[i].id_produk %>" 
                                       class="btn btn-sm btn-warning me-1">
                                        Edit
                                    </a>
                                    <a href="/produk/delete/<%= data[i].id_produk %>" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Yakin ingin menghapus data ini?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-muted py-4">
                                Data produk belum tersedia
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>