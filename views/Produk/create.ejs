<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><%= title %></h5>
                </div>
                <div class="card-body">
                    <form action="/produk/store" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="nama_produk" class="form-label">Nama Produk</label>
                            <input type="text" class="form-control" id="nama_produk" name="nama_produk" value="<%= nama_produk %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="harga_produk" class="form-label">Harga</label>
                            <input type="number" class="form-control" id="harga_produk" name="harga_produk" value="<%= harga_produk %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="id_kategori" class="form-label">Kategori</label>
                            <input list="kategori-list" type="text" class="form-control" id="id_kategori" name="id_kategori" value="<%= id_kategori %>" placeholder="Ketik atau pilih kategori" required>
                            <datalist id="kategori-list">
                                <% kategori.forEach(function(kat) { %>
                                    <option value="<%= kat.nama_kategori %>"></option>
                                <% }); %>
                            </datalist>
                        </div>
                        <div class="mb-3">
                            <label for="gambar_produk" class="form-label">Gambar Produk</label>
                            <input type="file" class="form-control" id="gambar_produk" name="gambar_produk" accept="image/*">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Preview Gambar</label>
                            <div class="border rounded p-2 text-center">
                                <img id="preview-gambar" src="" alt="Preview Gambar" class="img-fluid" style="max-height: 250px; display: none;">
                                <p id="preview-placeholder" class="text-muted mb-0">Belum memilih gambar</p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="/produk" class="btn btn-secondary">Kembali</a>
                            <button type="submit" class="btn btn-primary">Simpan</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const createInput = document.getElementById('gambar_produk');
    const createPreview = document.getElementById('preview-gambar');
    const createPlaceholder = document.getElementById('preview-placeholder');

    createInput.addEventListener('change', function() {
        const file = this.files[0];
        if (!file) {
            createPreview.style.display = 'none';
            createPlaceholder.style.display = 'block';
            return;
        }

        const reader = new FileReader();
        reader.onload = function(e) {
            createPreview.src = e.target.result;
            createPreview.style.display = 'block';
            createPlaceholder.style.display = 'none';
        };
        reader.readAsDataURL(file);
    });
</script>
</body>
</html>
